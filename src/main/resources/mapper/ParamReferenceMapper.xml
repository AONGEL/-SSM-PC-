<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hardware.dao.ParamReferenceDao">

    <resultMap id="ParamReferenceResultMap" type="com.hardware.entity.ParamReference">
        <id property="id" column="id"/>
        <result property="postId" column="post_id"/>
        <result property="replyId" column="reply_id"/>
        <result property="paramTable" column="param_table"/>
        <result property="paramId" column="param_id"/>
        <result property="referenceText" column="reference_text"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="ParamReferenceResultMap">
        SELECT id, post_id, reply_id, param_table, param_id, reference_text, create_time
        FROM param_reference
        WHERE id = #{id}
    </select>

    <select id="selectByPostId" parameterType="java.lang.Integer" resultMap="ParamReferenceResultMap">
        SELECT id, post_id, reply_id, param_table, param_id, reference_text, create_time
        FROM param_reference
        WHERE post_id = #{postId}
    </select>

    <select id="selectByReplyId" parameterType="java.lang.Integer" resultMap="ParamReferenceResultMap">
        SELECT id, post_id, reply_id, param_table, param_id, reference_text, create_time
        FROM param_reference
        WHERE reply_id = #{replyId}
    </select>

    <insert id="insert" parameterType="com.hardware.entity.ParamReference" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO param_reference (post_id, reply_id, param_table, param_id, reference_text, create_time)
        VALUES (#{postId}, #{replyId}, #{paramTable}, #{paramId}, #{referenceText}, NOW())
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM param_reference WHERE id = #{id}
    </delete>

</mapper>
