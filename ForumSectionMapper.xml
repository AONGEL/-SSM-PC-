<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hardware.dao.ForumSectionDao">

    <resultMap id="ForumSectionResultMap" type="com.hardware.entity.ForumSection">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectAll" resultMap="ForumSectionResultMap">
        SELECT id, name, description, create_time FROM forum_section
    </select>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="ForumSectionResultMap">
        SELECT id, name, description, create_time FROM forum_section WHERE id = #{id}
    </select>

</mapper>
